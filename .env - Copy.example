# ============================================================
# Vehicle Maintenance Logger — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Find these at: supabase.com → your project → Settings → API

# Project URL (safe to expose in frontend)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Anon/public key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inh4eHh4eHh4eHh4eHh4eHh4eHh4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE2MDAwMDAwMDAsImV4cCI6MTkwMDAwMDAwMH0.REPLACE_THIS

# Service role key — NEVER expose client-side, server only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inh4eHh4eHh4eHh4eHh4eHh4eHh4Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTYwMDAwMDAwMCwiZXhwIjoxOTAwMDAwMDAwfQ.REPLACE_THIS

# ── OpenAI (Whisper STT) ──────────────────────────────────────
# Find at: platform.openai.com → API keys
OPENAI_API_KEY=sk-proj-REPLACE_THIS

# ── Anthropic (Claude parsing) ────────────────────────────────
# Find at: console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-REPLACE_THIS

# ── Test credentials (layer 2 tests only) ────────────────────
# A real account in your Supabase auth — used to get a JWT for API tests
TEST_EMAIL=your@email.com
TEST_PASSWORD=yourpassword

# Base URL for API tests (local dev or production)
TEST_BASE_URL=http://localhost:3000
