{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ],
  "functions": {
    "api/transcribe.js": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/parse-log.js": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/vehicles.js": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/logs.js": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/logs/[id].js": {
      "maxDuration": 10,
      "memory": 256
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PATCH, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    }
  ]
}
